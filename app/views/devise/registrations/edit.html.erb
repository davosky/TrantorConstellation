<div class="row justify-content-center">
  <div class="col-md-4 text-center">
    <br/>
    &emsp;
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="input-group mb-3 shadow">
        <span class="bg-primary text-white input-group-text input-group-text-fixed-lenght">
          <i class="fa-solid fa-at"></i>&nbsp;E-Mail
        </span>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
      </div>
      <div class="input-group mb-1 shadow">
        <span class="bg-primary text-white input-group-text input-group-text-fixed-lenght">
          <i class="fa-solid fa-key"></i>&nbsp;Nuova Password
        </span>
        <%= f.password_field :password, autofocus: true, autocomplete: "password", class: "form-control" %>
      </div>
      <i>(<%= t('.leave_blank_if_you_don_t_want_to_change_it') %>)</i>
      <div class="input-group mb-3 mt-3 shadow">
        <span class="bg-primary text-white input-group-text input-group-text-fixed-lenght">
          <i class="fa-solid fa-key"></i>&nbsp;Conferma Nuova Password
        </span>
        <%= f.password_field :password_confirmation, autocomplete: "new password", class: "form-control" %>
      </div>
      <div class="input-group mb-1 shadow">
        <span class="bg-primary text-white input-group-text input-group-text-fixed-lenght">
          <i class="fa-solid fa-key"></i>&nbsp;Password Attuale
        </span>
        <%= f.password_field :current_password, autocomplete: "current password", class: "form-control" %>
      </div>
      <i>(<%= t('.we_need_your_current_password_to_confirm_your_changes') %>)</i>
      <div class="d-grid mt-3 mb-1">
        <%= button_tag(type: "submit", class: "btn btn-outline-primary shadow") do %>
          <strong>
            <i class="fas fa-sign-in-alt"></i>&ensp;CONFERMA MODIFICHE
          </strong>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
