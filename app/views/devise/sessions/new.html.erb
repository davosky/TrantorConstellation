<div class="text-center">
  <%= image_tag("login/logos/login_logo.svg", class: "img-fluid") %>
</div>
<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <div class="mb-3">
    <%= f.label :username, class: "form-label text-success" %><br />
    <%= f.text_field :username, autofocus: true, class: "form-control border border-success" %>
  </div>
  <div class="mb-3">
    <%= f.label :password, class: "form-label text-success" %><br />
    <%= f.password_field :password, autocomplete: "current-password", class: "form-control border border-success" %>
  </div>
  <div class="d-grid gap-2 mt-3">
    <%= f.submit "Log in", class: "btn btn-success" %>
  </div>
<% end %>
