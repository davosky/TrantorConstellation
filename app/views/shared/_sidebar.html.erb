<div id="bdSidebar" class="d-flex flex-column flex-shrink-0 p-3 bg-success
 text-white offcanvas-md offcanvas-start">
  <%= link_to root_path, class: "navbar-brand" do %>
    <%= image_tag("sidebar/logos/sidebar_logo.svg", class: "img-fluid") %>
  <% end %>
  <hr>
  <ul class="mynav nav nav-pills flex-column mb-auto">
    <li class="nav-item mb-1">
      <%= link_to home_index_path do %>
        <i class="fa-solid fa-home"></i>
        &nbsp;
        HOME
      <% end %>
    </li>
    <li class="sidebar-item  nav-item mb-1">
      <a href="#" class="sidebar-link collapsed" data-bs-toggle="collapse" data-bs-target="#reimbursments" aria-expanded="false" aria-controls="reimbursments">
        <i class="fa-solid fa-receipt"></i>
        &nbsp;
        <span class="topic">RIMBORSI</span>
      </a>
      <ul id="reimbursments" class="sidebar-dropdown list-unstyled collapse bg-dark rounded border border-light" data-bs-parent="#sidebar">
        <li class="sidebar-item">
          <%= link_to "#" do %>
            <i class="fa-solid fa-receipt"></i>
            &nbsp;
            Rimborsi
          <% end %>
        </li>
        <li class="sidebar-item">
          <hr class="text-white">
        </li>
        <li class="sidebar-item px-2 mb-2 text-success-light">
          <i class="fa-solid fa-repeat"></i>
          &nbsp;
          ricorsivi
