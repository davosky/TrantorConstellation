        <li class="sidebar-item">
          <%= link_to mission_reasons_path do %>
            <i class="fa-solid fa-person-walking-luggage"></i>
            &nbsp;
            Motivi Missione
          <% end %>
        </li>
        <li class="sidebar-item">
          <%= link_to mission_paths_path do %>
            <i class="fa-solid fa-map-location-dot"></i>
            &nbsp;
            Percorsi Missione
          <% end %>
        </li>
        <li class="sidebar-item">
          <%= link_to mission_places_path do %>
            <i class="fa-solid fa-city"></i>
            &nbsp;
            Luoghi Missione
          <% end %>
        </li>
        <li class="sidebar-item">
          <%= link_to mission_structures_path do %>
            <i class="fa-solid fa-building"></i>
            &nbsp;
            Strutture Missione
          <% end %>
        </li>
      </ul>
    </li>
    <li class="sidebar-item  nav-item mb-1">
      <a href="#" class="sidebar-link collapsed" data-bs-toggle="collapse" data-bs-target="#modules" aria-expanded="false" aria-controls="modules">
        <i class="fa-solid fa-cog"></i>
        &nbsp;
        <span class="topic">MODULI</span>
      </a>
      <ul id="modules" class="sidebar-dropdown list-unstyled collapse bg-dark rounded border border-light" data-bs-parent="#sidebar">
        <li class="sidebar-item">
          <%= link_to veichles_path do %>
            <i class="fa-solid fa-car"></i>
            &nbsp;
            Veicoli
          <% end %>
        </li>
        <li class="sidebar-item">
          <%= link_to transports_path do %>
            <i class="fa-solid fa-train"></i>
            &nbsp;
            Trasporti
          <% end %>
        </li>
      </ul>
    </li>
  </ul>
  <hr>
  <div class="d-flex">
    <div class="dropdown pb-4">
      <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
        <%= image_tag("sidebar/icons/sidebar_user_icon.svg", class: "rounded-circle img-fluid") %>
        &nbsp;
        <span class="d-none d-sm-inline mx-1">Trantor</span>
      </a>
      <ul class="dropdown-menu dropdown-menu-dark text-small shadow" aria-labelledby="dropdownUser1">
        <% unless !admin %>
          <%= link_to rails_admin_path, class: "dropdown-item" do %>
            <i class="fa-solid fa-cogs"></i>
            &nbsp;
            AMMINISTRAZIONE
          <% end %>
        <% end %>
        <hr class="p-1"/>
        <%= link_to destroy_operator_session_path, method: :get, class: "dropdown-item" do %>
          <i class="fa-solid fa-door-open"></i>
          &nbsp;
          USCITA
        <% end %>
      </ul>
    </div>
