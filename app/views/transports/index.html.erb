<div class="col-6 offset-3 p-3 border border-success rounded">
  <table class="table table-light table-hover rounded">
    <thead>
      <th><i class="fa-solid fa-train text-success" data-bs-toggle="tooltip" title="Modello"></i></th>
      <th><i class="fa-solid fa-arrow-up-9-1 text-success" data-bs-toggle="tooltip" title="Posizione"></i></th>
      <th colspan=2></th>
    </thead>
    <tbody>
      <% @transports.each do |transport| %>
        <tr>
          <td>
            <%= link_to transport_path(transport), "data-controller": "turbo", 
            "data-bs-toggle": "tooltip", 
            "title": "Visualizza il record corrente" do %>
              <%= transport.name %>
            <% end %>
          </td>
          <td><%= transport.position %></td>
          <td>
            <%= link_to edit_transport_path(transport), "data-controller": "turbo", 
            "data-bs-toggle": "tooltip", 
            "title": "Modifica il Record Corrente", class: "edit-link" do %>
              <i class="fa-solid fa-pen-to-square"></i>
            <% end %>
          </td>
          <td>
            <%= link_to transport_path(transport),
            "data-turbo-method": :delete,
            "data-turbo-confirm": "Sicuri di voler eliminare il record corrente?" , 
            "data-bs-toggle": "tooltip", 
            "title": "Elimina il Record Corrente", class: "delete-link" do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
