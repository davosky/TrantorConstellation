  <%= turbo_frame_tag :remote_modal, target: :_top do %>
  <div class="col-6 offset-3 p-3 border border-success rounded">
    <div class="row">
      <div class="col">
        <span class="text-success">
          <i class="fa-solid fa-car"></i>
          &emsp;
          Modello:
        </span>
        &emsp;
        <%= @veichle.model %>
        <hr class="text-success"/>
        <span class="text-success">
          <i class="fa-solid fa-industry"></i>
          &emsp;
          Produttore:
        </span>
        &emsp;
        <%= @veichle.producer %>
        <hr class="text-success"/>
        <span class="text-success">
          <i class="fa-solid fa-credit-card"></i>
          &emsp;
          Targa:
        </span>
        &emsp;
        <%= @veichle.license_plate %>
        <hr class="bg-success"/>
        <span class="text-success">
          <i class="fa-solid fa-arrow-up-9-1"></i>
          &emsp;
          Posizione in Scaletta:
        </span>
        &emsp;
        <%= @veichle.position %>
        <hr class="text-success"/>
        <span class="float-end">
          <%= link_to veichles_path, class: "btn btn-outline-success btn-sm" do %>
            <i class="fa-solid fa-arrow-left"></i>
            &nbsp;
            <i class="fa-solid fa-list"></i>
            &emsp;
            Ritorna alla Lista
          <% end %>
        </span>
      </div>
    </div>
  </div>
<% end %>
