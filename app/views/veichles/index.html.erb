<div class="col-6 offset-3 p-3 border border-success rounded">
  <table class="table table-light table-hover rounded">
    <thead>
      <th><i class="fa-solid fa-car text-success" data-bs-toggle="tooltip" title="Modello"></i></th>
      <th><i class="fa-solid fa-industry text-success" data-bs-toggle="tooltip" title="Produttore"></i></th>
      <th><i class="fa-solid fa-credit-card text-success" data-bs-toggle="tooltip" title="Targa"></i></th>
      <th><i class="fa-solid fa-arrow-up-9-1 text-success" data-bs-toggle="tooltip" title="Posizione"></i></th>
      <th colspan=2></th>
    </thead>
    <tbody>
      <% @veichles.each do |veichle| %>
        <tr>
          <td>
            <%= link_to veichle_path(veichle), "data-controller": "turbo", 
            "data-bs-toggle": "tooltip", 
            "title": "Visualizza il record corrente" do %>
              <%= veichle.model %>
            <% end %>
          </td>
          <td><%= veichle.producer %></td>
          <td><%= veichle.license_plate %></td>
          <td><%= veichle.position %></td>
          <td>
            <%= link_to edit_veichle_path(veichle), "data-controller": "turbo", 
            "data-bs-toggle": "tooltip", 
            "title": "Modifica il Record Corrente", class: "edit-link" do %>
              <i class="fa-solid fa-pen-to-square"></i>
            <% end %>
          </td>
          <td>
            <%= link_to veichle_path(veichle),
            "data-turbo-method": :delete,
            "data-turbo-confirm": "Sicuri di voler eliminare il record corrente?" , 
            "data-bs-toggle": "tooltip", 
            "title": "Elimina il Record Corrente", class: "delete-link" do %>
              <i class="fa-solid fa-trash"></i>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
